<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Leaderboard</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <h1>Leaderboard</h1>
        <table>
            <thead>
                <tr>
                    <th>Rank</th>
                    <th>Name</th>
                    <th>Attempts</th>
                    <th>Mode</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                <% scores.forEach((score, index) => { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td><%= score.name %></td>
                        <td><%= score.attempts %></td>
                        <td><%= gameModes[score.gameMode]?.name || score.gameMode %></td>
                        <td><%= score.date.toLocaleDateString() %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
        <a href="/" class="btn">Home</a>
        <a href="/game" class="btn">Play Game</a>
    </div>
</body>
</html>