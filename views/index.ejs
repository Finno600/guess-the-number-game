<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Guess the Number Game</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <h1>Welcome to Guess the Number!</h1>
        <p>Choose your difficulty level and try to guess the number in as few attempts as possible.</p>
        <div class="modes">
            <% Object.keys(gameModes).forEach(mode => { %>
                <a href="/game?mode=<%= mode %>" class="btn mode-btn"><%= gameModes[mode].name %></a>
            <% }); %>
        </div>
        <a href="/leaderboard" class="btn">View Leaderboard</a>
    </div>
</body>
</html>